---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin Dashboard | Jernal" description="Admin Dashboard for Jernal. Queue, schedule, and manage daily creative and personal writing prompts.">
  <div id="admin-container">
    <!-- 1. LOADING STATE -->
    <div id="admin-loading" class="glass-container auth-card">
      <div class="loading-spinner"></div>
      <h2>Verifying Admin Credentials...</h2>
      <p>Please wait a moment while we check your access level.</p>
    </div>

    <!-- 2. UNAUTHORIZED STATE -->
    <div id="admin-unauthorized" class="glass-container auth-card" style="display: none;">
      <div class="error-icon">⚠️</div>
      <h2 class="error-title">Access Denied</h2>
      <p id="unauthorized-message">You do not have administrative privileges to access this dashboard.</p>
      <div class="auth-actions">
        <button id="admin-signin-btn" class="btn-cta">Sign In as Admin</button>
        <a href="/" class="btn-secondary">Go to Homepage</a>
      </div>
    </div>

    <!-- 3. AUTHORIZED DASHBOARD -->
    <div id="admin-dashboard" style="display: none; width: 100%; max-width: 1000px; margin: 0 auto; padding: 20px;">
      
      <!-- Dashboard Header -->
      <div class="dashboard-header glass-container">
        <div>
          <h1 class="glow-title">Admin Dashboard</h1>
          <p class="subtitle">Create and manage the daily writing prompt queue.</p>
        </div>
        <button id="admin-signout-btn" class="btn-signout">Sign Out</button>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card glass-container fiction-stat">
          <div class="stat-icon">📚</div>
          <div class="stat-info">
            <span class="stat-label">Fiction Queue</span>
            <h3 id="fiction-count" class="stat-value">0 prompts</h3>
            <p id="fiction-days" class="stat-days">0 days remaining</p>
          </div>
        </div>

        <div class="stat-card glass-container personal-stat">
          <div class="stat-icon">✍️</div>
          <div class="stat-info">
            <span class="stat-label">Personal Queue</span>
            <h3 id="personal-count" class="stat-value">0 prompts</h3>
            <p id="personal-days" class="stat-days">0 days remaining</p>
          </div>
        </div>
      </div>

      <!-- Tab Selection Bar -->
      <div class="filter-tabs" style="display: inline-flex; margin-bottom: 2rem; padding: 4px; border-radius: 16px;">
        <button id="btn-tab-queue" class="filter-tab active" style="font-size: 0.95rem; padding: 0.5rem 1.5rem; border-radius: 12px; font-weight: 700;">Prompts Queue</button>
        <button id="btn-tab-moderate" class="filter-tab" style="font-size: 0.95rem; padding: 0.5rem 1.5rem; border-radius: 12px; font-weight: 700;">Moderate Feed</button>
      </div>

      <!-- Tab Content 1: Prompts Queue -->
      <div id="tab-content-queue" class="dashboard-layout">
        
        <!-- Column 1: Add Prompt Form -->
        <div class="form-panel glass-container">
          <h2 class="section-title">Queue a New Prompt</h2>
          <form id="add-prompt-form">
            
            <div class="form-group">
              <label class="input-label">Category</label>
              <div class="category-cards">
                <label class="category-card fiction">
                  <input type="radio" name="category" value="fiction" checked />
                  <span class="card-title">Fiction</span>
                  <span class="card-desc">Sci-fi, fantasy, drama</span>
                </label>
                <label class="category-card personal">
                  <input type="radio" name="category" value="personal" />
                  <span class="card-title">Personal</span>
                  <span class="card-desc">Memoirs, prompts, letters</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label for="prompt-input" class="input-label">Prompt Content</label>
              <textarea 
                id="prompt-input" 
                placeholder="Type a creative prompt that will challenge or inspire writers..." 
                required
                rows="5"
              ></textarea>
            </div>

            <button type="submit" id="submit-prompt-btn" class="btn-cta btn-block">
              Add to Queue
            </button>
          </form>
        </div>

        <!-- Column 2: Prompt List / Queue View -->
        <div class="queue-panel glass-container">
          <div class="queue-header">
            <h2 id="queue-title" class="section-title">Upcoming Queue</h2>
            <div class="queue-filters">
              <div class="filter-tabs time-filters">
                <button class="filter-tab active" data-time="upcoming">Today & Onwards</button>
                <button class="filter-tab" data-time="past">Past</button>
              </div>
              <div class="filter-tabs category-filters">
                <button class="filter-tab active" data-filter="all">All</button>
                <button class="filter-tab" data-filter="fiction">Fiction</button>
                <button class="filter-tab" data-filter="personal">Personal</button>
              </div>
            </div>
          </div>

          <div id="queue-list" class="queue-list">
            <!-- Dynamically populated -->
            <div class="empty-state">No upcoming prompts queued up. Add one above!</div>
          </div>
        </div>

      </div>

      <!-- Tab Content 2: Moderate Feed -->
      <div id="tab-content-moderate" style="display: none;">
        <div class="dashboard-layout">
          <!-- Column 1: Recent Community Posts -->
          <div class="queue-panel glass-container">
            <h2 class="section-title">Recent Community Feed Posts</h2>
            <div id="mod-posts-list" class="queue-list" style="max-height: 600px; overflow-y: auto;">
              <!-- Dynamically populated -->
              <div class="empty-state">Loading feed posts...</div>
            </div>
          </div>

          <!-- Column 2: Suspended Writers -->
          <div class="form-panel glass-container" style="max-height: 680px; display: flex; flex-direction: column;">
            <h2 class="section-title">Suspended Community Feed Writers</h2>
            <div id="mod-blocked-list" class="queue-list" style="max-height: 600px; overflow-y: auto;">
              <!-- Dynamically populated -->
              <div class="empty-state">Loading suspended list...</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Toast Notification -->
  <div id="admin-toast" class="toast">Action completed successfully!</div>
</Layout>

<style>
  #admin-container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 1.5rem 40px 1.5rem;
  }

  /* Centered Auth/Loading cards */
  .auth-card {
    text-align: center;
    color: var(--color-cream-light);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 2rem;
  }

  .loading-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid rgba(255, 255, 255, 0.1);
    border-top: 4px solid var(--color-blue);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .error-icon {
    font-size: 3rem;
  }

  .error-title {
    color: var(--color-red-light);
    margin: 0;
  }

  .auth-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-cream-light);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
  }

  /* Dashboard Layout */
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-cream-light);
    margin-bottom: 2rem;
    max-width: 100% !important;
  }

  .glow-title {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-red) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    margin: 0.25rem 0 0 0;
    font-size: 1rem;
    color: var(--color-cream-light);
  }

  .btn-signout {
    padding: 0.5rem 1.2rem;
    border-radius: 20px;
    border: 1px solid var(--color-red-dark);
    background: rgba(216, 30, 91, 0.1);
    color: var(--color-red-light);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-signout:hover {
    background: var(--color-red);
    color: white;
    box-shadow: 0 0 15px rgba(216, 30, 91, 0.4);
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 100% !important;
    padding: 1.5rem;
    color: var(--color-cream-light);
  }

  .stat-icon {
    font-size: 2.5rem;
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .fiction-stat .stat-icon {
    border-color: rgba(216, 30, 91, 0.25);
    box-shadow: inset 0 0 10px rgba(216, 30, 91, 0.1);
  }

  .personal-stat .stat-icon {
    border-color: rgba(0, 207, 193, 0.25);
    box-shadow: inset 0 0 10px rgba(0, 207, 193, 0.1);
  }

  .stat-info {
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-cream-light);
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0.15rem 0;
  }

  .fiction-stat .stat-value {
    color: var(--color-red-light);
  }

  .personal-stat .stat-value {
    color: var(--color-blue-light);
  }

  .stat-days {
    font-size: 0.85rem;
    margin: 0;
    color: var(--color-cream-light);
  }

  /* Dashboard Body Grid */
  .dashboard-layout {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .form-panel, .queue-panel {
    max-width: 100% !important;
    color: var(--color-cream-light);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .input-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-cream-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Segmented Category Selection */
  .category-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .category-card {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .category-card input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .category-card .card-title {
    font-size: 1.05rem;
    font-weight: 700;
  }

  .category-card .card-desc {
    font-size: 0.75rem;
    color: var(--color-cream-light);
  }

  /* Fiction Selection */
  .category-card.fiction:hover {
    border-color: rgba(216, 30, 91, 0.4);
    background: rgba(216, 30, 91, 0.03);
  }

  .category-card.fiction input:checked + .card-title,
  .category-card.fiction input:checked ~ .card-desc {
    color: #fff;
  }

  .category-card.fiction:has(input:checked) {
    border-color: var(--color-red-light);
    background: rgba(216, 30, 91, 0.12);
    box-shadow: 0 0 15px rgba(216, 30, 91, 0.15);
  }

  /* Personal Selection */
  .category-card.personal:hover {
    border-color: rgba(0, 207, 193, 0.4);
    background: rgba(0, 207, 193, 0.03);
  }

  .category-card.personal:has(input:checked) {
    border-color: var(--color-blue-light);
    background: rgba(0, 207, 193, 0.12);
    box-shadow: 0 0 15px rgba(0, 207, 193, 0.15);
  }

  /* Textarea form style */
  #prompt-input {
    width: 100%;
    padding: 1rem;
    font-size: 1rem;
    line-height: 1.5;
    color: #fff;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    resize: none;
    outline: none;
    transition: all 0.3s ease;
  }

  #prompt-input:focus {
    border-color: var(--color-blue);
    box-shadow: 0 0 10px rgba(0, 207, 193, 0.15);
  }

  .btn-cta {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: 20px;
    border: 1px solid var(--color-blue-dark);
    background: linear-gradient(135deg, var(--color-cream-dark) 0%, var(--color-cream) 100%);
    color: var(--color-blue-dark);
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
    transition: all 0.3s ease;
  }

  .btn-cta:hover {
    border-color: var(--color-blue);
    box-shadow: 0 0 15px rgba(0, 207, 193, 0.4);
  }

  .btn-cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-block {
    display: block;
    width: 100%;
  }

  /* Queue Panel Details */
  .queue-header {
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  .queue-header .section-title {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 10px;
  }

  .queue-filters {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-tabs {
    display: flex;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 15px;
    padding: 3px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .filter-tab {
    background: transparent;
    border: none;
    color: var(--color-cream-dark);
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .filter-tab:hover {
    color: #fff;
  }

  .filter-tab.active {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
  }

  .queue-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: 520px;
    overflow-y: auto;
    padding-right: 5px;
  }

  /* Scrollbar custom style */
  .queue-list::-webkit-scrollbar {
    width: 6px;
  }
  .queue-list::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.1);
  }
  .queue-list::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
  }

  .empty-state {
    text-align: center;
    color: var(--color-cream-dark);
    padding: 3rem 1rem;
    font-style: italic;
  }

  /* Toast Notification */
  .toast {
    position: fixed;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #ffffff;
    padding: 0.85rem 1.75rem;
    border-radius: 30px;
    font-size: 0.95rem;
    font-weight: 500;
    z-index: 10000;
    pointer-events: none;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transition: bottom 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.4s ease;
    opacity: 0;
  }

  .toast.show {
    bottom: 40px;
    opacity: 1;
  }

  @media (max-width: 900px) {
    .dashboard-layout {
      grid-template-columns: 1fr;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    #admin-container {
      align-items: flex-start;
      padding-top: 110px;
    }
    .dashboard-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .queue-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .queue-filters {
      width: 100%;
      justify-content: space-between;
    }
    .btn-signout {
      width: 100%;
    }
    .auth-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-cta, .btn-secondary {
      width: 100%;
    }
  }
</style>

<style is:global>
  /* Queue Item Card */
  .queue-list .queue-item {
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 12px;
    padding: 1.2rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: all 0.3s ease;
  }

  .queue-list .queue-item:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .queue-list .queue-item.fiction {
    border-left: 3px solid var(--color-red-light);
    background: rgba(216, 30, 91, 0.015);
  }

  .queue-list .queue-item.fiction:hover {
    background: rgba(216, 30, 91, 0.035);
    border-color: rgba(216, 30, 91, 0.2) rgba(216, 30, 91, 0.08) rgba(216, 30, 91, 0.08) var(--color-red-light);
  }

  .queue-list .queue-item.personal {
    border-left: 3px solid var(--color-blue-light);
    background: rgba(0, 207, 193, 0.015);
  }

  .queue-list .queue-item.personal:hover {
    background: rgba(0, 207, 193, 0.035);
    border-color: rgba(0, 207, 193, 0.2) rgba(0, 207, 193, 0.08) rgba(0, 207, 193, 0.08) var(--color-blue-light);
  }

  .queue-list .queue-item-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .queue-list .queue-tags {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .queue-list .badge-category {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 10px;
  }

  .queue-list .badge-category.fiction {
    background: rgba(216, 30, 91, 0.15);
    color: var(--color-red-light);
    border: 1px solid rgba(216, 30, 91, 0.3);
  }

  .queue-list .badge-category.personal {
    background: rgba(0, 207, 193, 0.15);
    color: var(--color-blue-light);
    border: 1px solid rgba(0, 207, 193, 0.3);
  }

  .queue-list .badge-rel-day {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-cream-light);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.5rem;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  .queue-list .badge-rel-day.today-badge {
    background: rgba(0, 207, 193, 0.1);
    color: var(--color-blue-light);
    border-color: rgba(0, 207, 193, 0.2);
  }

  .queue-list .badge-rel-day.past-badge {
    background: rgba(255, 255, 255, 0.01);
    color: rgba(255,255,255,0.25);
    text-decoration: line-through;
  }

  .queue-list .badge-date {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-cream-light);
  }

  .queue-list .queue-item-text {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-cream-light);
    margin: 0;
  }

  .queue-list .queue-item-actions {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    padding-top: 0.6rem;
  }

  .queue-list .btn-delete {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .queue-list .btn-delete:hover {
    color: var(--color-red-light);
    background: rgba(216, 30, 91, 0.05);
  }
</style>

<script>
  let supabaseInstance: any = null;
  async function getSupabase() {
    if (!supabaseInstance) {
      const module = await import('../lib/supabaseClient.js');
      supabaseInstance = module.supabase;
    }
    return supabaseInstance;
  }

  // 1. SELECT UI ELEMENTS
  const loadingPanel = document.getElementById('admin-loading');
  const unauthorizedPanel = document.getElementById('admin-unauthorized');
  const dashboardPanel = document.getElementById('admin-dashboard');
  const unauthorizedMessage = document.getElementById('unauthorized-message');
  
  const signinBtn = document.getElementById('admin-signin-btn');
  const signoutBtn = document.getElementById('admin-signout-btn');
  
  const addPromptForm = document.getElementById('add-prompt-form') as HTMLFormElement | null;
  const promptInput = document.getElementById('prompt-input') as HTMLTextAreaElement | null;
  const submitPromptBtn = document.getElementById('submit-prompt-btn') as HTMLButtonElement | null;
  
  const fictionCountEl = document.getElementById('fiction-count');
  const fictionDaysEl = document.getElementById('fiction-days');
  const personalCountEl = document.getElementById('personal-count');
  const personalDaysEl = document.getElementById('personal-days');
  
  const categoryFilterTabs = document.querySelectorAll('.category-filters .filter-tab');
  const timeFilterTabs = document.querySelectorAll('.time-filters .filter-tab');
  const queueTitleEl = document.getElementById('queue-title');
  const queueListEl = document.getElementById('queue-list');
  const toastEl = document.getElementById('admin-toast');

  // Moderation Tab selectors
  const btnTabQueue = document.getElementById('btn-tab-queue');
  const btnTabModerate = document.getElementById('btn-tab-moderate');
  const tabContentQueue = document.getElementById('tab-content-queue');
  const tabContentModerate = document.getElementById('tab-content-moderate');
  const modPostsList = document.getElementById('mod-posts-list');
  const modBlockedList = document.getElementById('mod-blocked-list');

  let activeFilter = 'all';
  let activeTimeFilter = 'upcoming';
  let cachedPrompts: any[] = [];

  // 2. HELPER: MOUNTAIN TIME DATE FUNCTIONS
  function getDenverDateString(date = new Date()) {
    const formatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Denver',
      year: 'numeric',
      month: 'numeric',
      day: 'numeric'
    });
    const parts = formatter.formatToParts(date);
    const partMap = Object.fromEntries(parts.map(p => [p.type, p.value]));
    const year = partMap.year;
    const month = partMap.month.padStart(2, '0');
    const day = partMap.day.padStart(2, '0');
    return `${year}-${month}-${day}`;
  }

  function addDays(dateStr: string, days: number) {
    const [year, month, day] = dateStr.split('-').map(Number);
    const date = new Date(Date.UTC(year, month - 1, day));
    date.setUTCDate(date.getUTCDate() + days);
    const y = date.getUTCFullYear();
    const m = String(date.getUTCMonth() + 1).padStart(2, '0');
    const d = String(date.getUTCDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function formatDateDisplay(dateStr: string) {
    const [year, month, day] = dateStr.split('-').map(Number);
    const date = new Date(Date.UTC(year, month - 1, day));
    // Display nicely in UTC fields to align with formatted string
    return date.toLocaleDateString('en-US', {
      timeZone: 'UTC',
      weekday: 'short',
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  }

  function getDaysBetween(dateStr1: string, dateStr2: string) {
    const d1 = new Date(dateStr1);
    const d2 = new Date(dateStr2);
    const diffTime = d1.getTime() - d2.getTime();
    return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  }

  function showToast(message: string) {
    if (!toastEl) return;
    toastEl.textContent = message;
    toastEl.classList.add('show');
    setTimeout(() => {
      toastEl.classList.remove('show');
    }, 3000);
  }

  // 3. AUTHENTICATION & ACCESS VERIFICATION
  async function checkAdminStatus() {
    if (!loadingPanel || !unauthorizedPanel || !dashboardPanel) return;

    try {
      const sb = await getSupabase();
      // 1. Get current auth session
      const { data: { session } } = await sb.auth.getSession();
      
      if (!session) {
        // Show unauthorized panel (request log in)
        loadingPanel.style.display = 'none';
        dashboardPanel.style.display = 'none';
        unauthorizedPanel.style.display = 'block';
        if (unauthorizedMessage) {
          unauthorizedMessage.textContent = 'Please sign in to access the administrator panel.';
        }
        return;
      }

      // 2. Check if user ID is in public.admins
      const { data: adminData, error } = await sb
        .from('admins')
        .select('email')
        .eq('id', session.user.id)
        .maybeSingle();

      if (error || !adminData) {
        // Logged in but not admin
        loadingPanel.style.display = 'none';
        dashboardPanel.style.display = 'none';
        unauthorizedPanel.style.display = 'block';
        if (unauthorizedMessage) {
          unauthorizedMessage.textContent = `Access Denied. The account (${session.user.email}) does not have administrative privileges.`;
        }
        return;
      }

      // 3. User is admin! Hide loading and show dashboard
      loadingPanel.style.display = 'none';
      unauthorizedPanel.style.display = 'none';
      dashboardPanel.style.display = 'block';

      // Load dashboard data
      loadDashboardData();
      loadModerationData();

    } catch (err) {
      console.error('Error verifying admin status:', err);
      loadingPanel.style.display = 'none';
      unauthorizedPanel.style.display = 'block';
    }
  }

  // Set up auth listeners
  signinBtn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-auth-modal'));
  });

  signoutBtn?.addEventListener('click', async () => {
    const sb = await getSupabase();
    await sb.auth.signOut();
    window.location.reload();
  });

  async function initAdmin() {
    const sb = await getSupabase();
    // Re-verify when auth state changes (e.g. login succeeds)
    sb.auth.onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' || event === 'SIGNED_OUT') {
        checkAdminStatus();
      }
    });

    // Initial check on load
    checkAdminStatus();
  }

  initAdmin();

  // 4. LOAD QUEUE & STATS DATA
  async function loadDashboardData() {
    try {
      const todayDenver = getDenverDateString();
      const sb = await getSupabase();

      // Fetch all prompts
      const { data: prompts, error } = await sb
        .from('prompts')
        .select('*')
        .order('scheduled_date', { ascending: true });

      if (error) throw error;
      cachedPrompts = prompts || [];

      // Calculate statistics
      calculateStats(todayDenver);

      // Render prompt queue
      renderQueue(todayDenver);

    } catch (err: any) {
      console.error('Error loading dashboard data:', err);
      showToast(`Error loading data: ${err.message || 'Unknown'}`);
    }
  }

  function calculateStats(todayDenver: string) {
    // We only count prompts scheduled for today or later
    const upcomingFiction = cachedPrompts.filter(
      p => p.category === 'fiction' && p.scheduled_date >= todayDenver
    );
    const upcomingPersonal = cachedPrompts.filter(
      p => p.category === 'personal' && p.scheduled_date >= todayDenver
    );

    // Update fiction stats
    if (fictionCountEl && fictionDaysEl) {
      fictionCountEl.textContent = `${upcomingFiction.length} prompt${upcomingFiction.length === 1 ? '' : 's'}`;
      fictionDaysEl.textContent = `${upcomingFiction.length} day${upcomingFiction.length === 1 ? '' : 's'} covered`;
    }

    // Update personal stats
    if (personalCountEl && personalDaysEl) {
      personalCountEl.textContent = `${upcomingPersonal.length} prompt${upcomingPersonal.length === 1 ? '' : 's'}`;
      personalDaysEl.textContent = `${upcomingPersonal.length} day${upcomingPersonal.length === 1 ? '' : 's'} covered`;
    }
  }

  // 5. RENDER QUEUE LIST
  function renderQueue(todayDenver: string) {
    if (!queueListEl) return;
    queueListEl.innerHTML = '';

    // Update queue title dynamically
    if (queueTitleEl) {
      queueTitleEl.textContent = activeTimeFilter === 'upcoming' ? 'Upcoming Queue' : 'Past Prompts';
    }

    // Filter prompts based on selected category filter
    let filtered = cachedPrompts;
    if (activeFilter !== 'all') {
      filtered = cachedPrompts.filter(p => p.category === activeFilter);
    }

    // Filter prompts based on time filter
    if (activeTimeFilter === 'upcoming') {
      filtered = filtered.filter(p => p.scheduled_date >= todayDenver);
    } else {
      filtered = filtered.filter(p => p.scheduled_date < todayDenver);
      // Sort descending (newest past first)
      filtered = [...filtered].reverse();
    }

    if (filtered.length === 0) {
      queueListEl.innerHTML = activeTimeFilter === 'upcoming'
        ? '<div class="empty-state">No upcoming prompts scheduled. Add one above!</div>'
        : '<div class="empty-state">No past prompts found.</div>';
      return;
    }

    filtered.forEach((prompt) => {
      const isPast = prompt.scheduled_date < todayDenver;
      const isToday = prompt.scheduled_date === todayDenver;
      
      let relDayText = '';
      let badgeClass = 'badge-rel-day';
      
      if (isPast) {
        relDayText = 'Past';
        badgeClass += ' past-badge';
      } else if (isToday) {
        relDayText = 'Today';
        badgeClass += ' today-badge';
      } else {
        const daysAway = getDaysBetween(prompt.scheduled_date, todayDenver);
        if (daysAway === 1) {
          relDayText = 'Tomorrow';
        } else {
          relDayText = `In ${daysAway} days`;
        }
      }

      const itemCard = document.createElement('div');
      itemCard.className = `queue-item ${prompt.category}`;
      
      itemCard.innerHTML = `
        <div class="queue-item-meta">
          <div class="queue-tags">
            <span class="badge-category ${prompt.category}">${prompt.category.toUpperCase()}</span>
            <span class="${badgeClass}">${relDayText}</span>
          </div>
          <span class="badge-date">${formatDateDisplay(prompt.scheduled_date)}</span>
        </div>
        <p class="queue-item-text">${prompt.prompt_text}</p>
        ${!isPast ? `
        <div class="queue-item-actions">
          <button class="btn-delete" data-id="${prompt.id}" data-category="${prompt.category}" data-date="${prompt.scheduled_date}">
            Delete & Shift
          </button>
        </div>
        ` : ''}
      `;

      // Set delete event listener (only if not past)
      if (!isPast) {
        const deleteBtn = itemCard.querySelector('.btn-delete');
        deleteBtn?.addEventListener('click', async (e) => {
          const target = e.currentTarget as HTMLElement;
          const id = target.dataset.id || '';
          const category = target.dataset.category || '';
          const date = target.dataset.date || '';

          if (confirm(`Are you sure you want to delete this prompt? Subsequent queued prompts for ${category} will shift back by one day.`)) {
            target.textContent = 'Deleting...';
            (target as HTMLButtonElement).disabled = true;
            await performDeleteAndShift(id, category, date);
          }
        });
      }

      queueListEl.appendChild(itemCard);
    });
  }

  // 6. ADD PROMPT SUBMISSION
  addPromptForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!promptInput || !submitPromptBtn) return;

    const promptText = promptInput.value.trim();
    if (!promptText) return;

    // Get selected category
    const categoryEl = addPromptForm.querySelector('input[name="category"]:checked') as HTMLInputElement | null;
    const category = categoryEl?.value || 'fiction';

    // Disable button
    submitPromptBtn.disabled = true;
    const originalText = submitPromptBtn.textContent;
    submitPromptBtn.textContent = 'Queueing...';

    try {
      const todayDenver = getDenverDateString();
      const sb = await getSupabase();

      // 1. Find the latest scheduled prompt for this category
      const { data: latestPrompt, error: fetchError } = await sb
        .from('prompts')
        .select('scheduled_date')
        .eq('category', category)
        .order('scheduled_date', { ascending: false })
        .limit(1)
        .maybeSingle();

      if (fetchError) throw fetchError;

      // 2. Compute scheduled date
      let scheduledDate = todayDenver;
      if (latestPrompt && latestPrompt.scheduled_date) {
        if (latestPrompt.scheduled_date >= todayDenver) {
          scheduledDate = addDays(latestPrompt.scheduled_date, 1);
        }
      }

      // 3. Insert prompt
      const { error: insertError } = await sb
        .from('prompts')
        .insert({
          category,
          prompt_text: promptText,
          scheduled_date: scheduledDate
        });

      if (insertError) throw insertError;

      showToast(`Prompt queued successfully for ${formatDateDisplay(scheduledDate)}!`);
      
      // Clear input
      promptInput.value = '';
      
      // Clear clients prompt cache for this category so they see changes if they check
      sessionStorage.removeItem(`jernel_daily_prompt_${category}`);

      // Reload
      loadDashboardData();

    } catch (err: any) {
      console.error('Error queueing prompt:', err);
      showToast(`Failed to queue prompt: ${err.message || 'Unknown error'}`);
    } finally {
      submitPromptBtn.disabled = false;
      submitPromptBtn.textContent = originalText;
    }
  });

  // 7. DELETE & SHIFT LOGIC
  async function performDeleteAndShift(id: string, category: string, date: string) {
    try {
      const sb = await getSupabase();
      // 1. Delete prompt
      const { error: deleteError } = await sb
        .from('prompts')
        .delete()
        .eq('id', id);

      if (deleteError) throw deleteError;

      // 2. Fetch subsequent prompts for this category sorted ascending
      const { data: subsequent, error: fetchError } = await sb
        .from('prompts')
        .select('id, scheduled_date')
        .eq('category', category)
        .gt('scheduled_date', date)
        .order('scheduled_date', { ascending: true });

      if (fetchError) throw fetchError;

      // 3. Shift dates back
      if (subsequent && subsequent.length > 0) {
        for (const prompt of subsequent) {
          const newDate = addDays(prompt.scheduled_date, -1);
          const { error: updateError } = await sb
            .from('prompts')
            .update({ scheduled_date: newDate })
            .eq('id', prompt.id);

          if (updateError) throw updateError;
        }
      }

      showToast('Prompt deleted and queue shifted successfully!');
      
      // Clear client caches
      sessionStorage.removeItem(`jernel_daily_prompt_${category}`);

      // Reload
      loadDashboardData();

    } catch (err: any) {
      console.error('Error during deletion and queue shift:', err);
      showToast(`Delete and shift failed: ${err.message || 'Unknown error'}`);
      loadDashboardData(); // Reload to sync UI
    }
  }

  // 8. FILTER TAB ACTIONS
  categoryFilterTabs.forEach((tab) => {
    tab.addEventListener('click', (e) => {
      categoryFilterTabs.forEach(t => t.classList.remove('active'));
      const target = e.currentTarget as HTMLElement;
      target.classList.add('active');
      activeFilter = target.dataset.filter || 'all';
      
      const todayDenver = getDenverDateString();
      renderQueue(todayDenver);
    });
  });

  timeFilterTabs.forEach((tab) => {
    tab.addEventListener('click', (e) => {
      timeFilterTabs.forEach(t => t.classList.remove('active'));
      const target = e.currentTarget as HTMLElement;
      target.classList.add('active');
      activeTimeFilter = target.dataset.time || 'upcoming';
      
      const todayDenver = getDenverDateString();
      renderQueue(todayDenver);
    });
  });

  // 9. ADMIN TAB NAVIGATION
  btnTabQueue?.addEventListener('click', () => {
    btnTabQueue.classList.add('active');
    btnTabModerate?.classList.remove('active');
    if (tabContentQueue) tabContentQueue.style.display = 'grid';
    if (tabContentModerate) tabContentModerate.style.display = 'none';
  });

  btnTabModerate?.addEventListener('click', () => {
    btnTabModerate.classList.add('active');
    btnTabQueue?.classList.remove('active');
    if (tabContentQueue) tabContentQueue.style.display = 'none';
    if (tabContentModerate) tabContentModerate.style.display = 'block';
    loadModerationData();
  });

  // 10. MODERATION LOGIC & RENDERING
  async function loadModerationData() {
    if (!modPostsList || !modBlockedList) return;

    try {
      const sb = await getSupabase();

      // 1. Fetch recent responses
      const { data: posts, error: postsError } = await sb
        .from('responses')
        .select('*')
        .eq('is_public', true)
        .order('created_at', { ascending: false })
        .limit(50);

      if (postsError) throw postsError;

      // 2. Fetch suspended users
      const { data: blocked, error: blockedError } = await sb
        .rpc('get_blocked_users_admin');

      if (blockedError) throw blockedError;

      renderModerationPosts(posts || []);
      renderModerationBlocked(blocked || []);

    } catch (err: any) {
      console.error('Error loading moderation data:', err);
      showToast(`Moderation load failed: ${err.message || 'Unknown'}`);
    }
  }

  function renderModerationPosts(posts: any[]) {
    if (!modPostsList) return;
    modPostsList.innerHTML = '';

    if (posts.length === 0) {
      modPostsList.innerHTML = '<div class="empty-state">No public community posts found.</div>';
      return;
    }

    posts.forEach((post) => {
      const isHidden = post.hidden_by_admin === true;
      const card = document.createElement('div');
      card.className = 'queue-item';
      if (isHidden) {
        card.style.opacity = '0.65';
        card.style.borderColor = 'rgba(216, 30, 91, 0.3)';
        card.style.background = 'rgba(216, 30, 91, 0.02)';
      }

      const date = new Date(post.created_at);
      const dateFormatted = date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });

      card.innerHTML = `
        <div class="queue-item-meta" style="margin-bottom: 0.5rem;">
          <div class="queue-tags">
            <span class="badge-category ${post.category}">${post.category.toUpperCase()}</span>
            ${isHidden ? '<span class="badge-category fiction" style="background: rgba(216, 30, 91, 0.15); color: var(--color-red-light); border: 1.5px solid rgba(216, 30, 91, 0.3); font-size: 0.65rem; padding: 0.1rem 0.4rem; border-radius: 6px;">HIDDEN</span>' : ''}
          </div>
          <span class="badge-date">${dateFormatted}</span>
        </div>
        <p class="queue-item-text" style="font-weight: 700; margin: 0 0 0.5rem 0; font-size: 0.9rem; color: rgba(255,255,255,0.85);">Author: ${post.writer_name || 'Anonymous Writer'}</p>
        <p class="queue-item-text" style="font-family: 'Times New Roman', serif; font-size: 1.05rem; padding: 0.85rem; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.03); border-radius: 8px; margin-bottom: 0.75rem; white-space: pre-wrap; line-height: 1.5;">${post.response_text}</p>
        <div class="queue-item-actions" style="display: flex; gap: 0.5rem; justify-content: flex-end; border-top: 1px solid rgba(255,255,255,0.03); padding-top: 0.5rem;">
          <button class="btn-delete btn-mod-toggle-hide" data-id="${post.id}" data-hidden="${isHidden}" style="color: ${isHidden ? 'var(--color-blue-light)' : 'var(--color-red-light)'};">
            ${isHidden ? 'Unhide Post' : 'Hide Post'}
          </button>
          <button class="btn-delete btn-mod-toggle-block" data-user-id="${post.user_id}" data-username="${post.writer_name || 'Anonymous Writer'}" style="color: var(--color-red-light);">
            Suspend Writer
          </button>
        </div>
      `;

      // Hide/Unhide handler
      const hideBtn = card.querySelector('.btn-mod-toggle-hide') as HTMLButtonElement | null;
      hideBtn?.addEventListener('click', async () => {
        hideBtn.disabled = true;
        try {
          const sb = await getSupabase();
          const { error } = await sb
            .from('responses')
            .update({ hidden_by_admin: !isHidden })
            .eq('id', post.id);

          if (error) throw error;
          showToast(isHidden ? 'Post restored to feed.' : 'Post hidden from feed.');
          loadModerationData();
        } catch (err: any) {
          console.error(err);
          showToast(`Action failed: ${err.message}`);
          hideBtn.disabled = false;
        }
      });

      // Block handler
      const blockBtn = card.querySelector('.btn-mod-toggle-block') as HTMLButtonElement | null;
      blockBtn?.addEventListener('click', async () => {
        const username = post.writer_name || 'Anonymous Writer';
        if (!confirm(`Are you sure you want to suspend user "${username}" from posting to the community feed? All their current posts will also be hidden.`)) return;
        blockBtn.disabled = true;

        try {
          const sb = await getSupabase();
          const { error } = await sb
            .from('blocked_users')
            .insert({ id: post.user_id, username: username });

          if (error) throw error;
          showToast('Writer suspended successfully.');
          loadModerationData();
        } catch (err: any) {
          console.error(err);
          showToast(`Action failed: ${err.message}`);
          blockBtn.disabled = false;
        }
      });

      modPostsList.appendChild(card);
    });
  }

  function renderModerationBlocked(blocked: any[]) {
    if (!modBlockedList) return;
    modBlockedList.innerHTML = '';

    if (blocked.length === 0) {
      modBlockedList.innerHTML = '<div class="empty-state">No suspended writers.</div>';
      return;
    }

    blocked.forEach((user) => {
      const card = document.createElement('div');
      card.className = 'queue-item';
      card.style.borderLeft = '3px solid var(--color-red-light)';
      card.style.background = 'rgba(216, 30, 91, 0.02)';

      const date = new Date(user.blocked_at);
      const dateFormatted = date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });

      card.innerHTML = `
        <div class="queue-item-meta" style="margin-bottom: 0.5rem;">
          <span class="badge-category fiction" style="background: rgba(216, 30, 91, 0.15); color: var(--color-red-light); border: 1.5px solid rgba(216, 30, 91, 0.3); font-size: 0.65rem; padding: 0.1rem 0.4rem; border-radius: 6px;">SUSPENDED</span>
          <span class="badge-date">${dateFormatted}</span>
        </div>
        <p class="queue-item-text" style="font-weight: 700; margin: 0; font-size: 0.95rem;">${user.username || 'Anonymous Writer'}</p>
        <p class="queue-item-text" style="font-size: 0.8rem; color: rgba(255,255,255,0.55); margin: 0.15rem 0 0.5rem 0; word-break: break-all;">${user.email || 'No email associated'}</p>
        <div class="queue-item-actions" style="display: flex; justify-content: flex-end; border-top: 1px solid rgba(255,255,255,0.03); padding-top: 0.5rem;">
          <button class="btn-delete btn-mod-unblock" data-user-id="${user.blocked_user_id}" style="color: var(--color-blue-light);">
            Unblock Writer
          </button>
        </div>
      `;

      // Unblock handler
      const unblockBtn = card.querySelector('.btn-mod-unblock') as HTMLButtonElement | null;
      unblockBtn?.addEventListener('click', async () => {
        const username = user.username || 'Anonymous Writer';
        if (!confirm(`Are you sure you want to lift the community feed suspension for "${username}"?`)) return;
        unblockBtn.disabled = true;

        try {
          const sb = await getSupabase();
          const { error } = await sb
            .from('blocked_users')
            .delete()
            .eq('id', user.blocked_user_id);

          if (error) throw error;
          showToast('Writer suspension lifted.');
          loadModerationData();
        } catch (err: any) {
          console.error(err);
          showToast(`Action failed: ${err.message}`);
          unblockBtn.disabled = false;
        }
      });

      modBlockedList.appendChild(card);
    });
  }
</script>
