---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import AuthModal from "../components/AuthModal.astro";

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Jernal",
	description = "Jernal is a daily writing prompt platform. Choose between fiction and personal prompts each day to write, save, and share your stories."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png?v=2" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.svg?v=2" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://cnwpofzjebxppenjkjmm.supabase.co" crossorigin />
		<link rel="dns-prefetch" href="https://cnwpofzjebxppenjkjmm.supabase.co" />
		<title>{title}</title>
	</head>
	<body>
		<Navbar />
		<AuthModal />

		<div class="bg-glows">
			<div class="orb orb-1"></div>
			<div class="orb orb-2"></div>
			<div class="orb orb-3"></div>
		</div>

		<div class="dots">
			<span class="dot" style="--i:15; --left:4%; --size:6px; --delay:-2s; --color:#a855f7;"></span>
			<span class="dot" style="--i:19; --left:12%; --size:14px; --delay:-7s; --color:#06b6d4; --blur:2px; --opacity:0.35;"></span>
			<span class="dot" style="--i:12; --left:21%; --size:8px; --delay:-15s; --color:#ec4899;"></span>
			<span class="dot" style="--i:22; --left:29%; --size:5px; --delay:-4s; --color:#3b82f6;"></span>
			<span class="dot" style="--i:14; --left:37%; --size:16px; --delay:-11s; --color:#a855f7; --blur:3px; --opacity:0.3;"></span>
			<span class="dot" style="--i:25; --left:52%; --size:10px; --delay:-18s; --color:#ffffff;"></span>
			<span class="dot" style="--i:11; --left:59%; --size:12px; --delay:-1s; --color:#ec4899; --blur:1px; --opacity:0.4;"></span>
			<span class="dot" style="--i:18; --left:67%; --size:6px; --delay:-23s; --color:#3b82f6;"></span>
			<span class="dot" style="--i:15; --left:74%; --size:15px; --delay:-5s; --color:#a855f7; --blur:2px; --opacity:0.35;"></span>
			<span class="dot" style="--i:20; --left:82%; --size:8px; --delay:-13s; --color:#06b6d4;"></span>
			<span class="dot" style="--i:13; --left:91%; --size:5px; --delay:-20s; --color:#ffffff;"></span>
			<span class="dot" style="--i:18; --left:18%; --size:5px; --delay:-3s; --color:#ec4899;"></span>
			<span class="dot" style="--i:21; --left:33%; --size:7px; --delay:-21s; --color:#a855f7;"></span>
			<span class="dot" style="--i:12; --left:56%; --size:13px; --delay:-19s; --color:#ec4899; --blur:2px; --opacity:0.35;"></span>
			<span class="dot" style="--i:23; --left:78%; --size:15px; --delay:-16s; --color:#06b6d4; --blur:3px; --opacity:0.3;"></span>
		</div>

		<slot />
	</body>
</html>

<style>
    .bg-glows {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        z-index: -2;
        pointer-events: none;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(140px);
        opacity: 0.35;
        mix-blend-mode: screen;
        animation: drift 25s ease-in-out infinite alternate;
        will-change: transform;
    }

    .orb-1 {
        top: -10%;
        left: -10%;
        width: 50vw;
        height: 50vw;
        background: radial-gradient(circle, var(--color-red) 0%, var(--color-red-light) 70%);
        animation-duration: 35s;
    }

    .orb-2 {
        bottom: -10%;
        right: -10%;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(circle, var(--color-blue) 0%, var(--color-blue-light) 70%);
        animation-duration: 40s;
        animation-delay: -5s;
    }

    .orb-3 {
        top: 40%;
        left: 50%;
        width: 45vw;
        height: 45vw;
        background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, rgba(219, 39, 119, 0) 70%);
        animation-duration: 30s;
        animation-delay: -10s;
    }

    @keyframes drift {
        0% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(8%, 12%) scale(1.15);
        }
        100% {
            transform: translate(-4%, -8%) scale(0.9);
        }
    }

    .dots {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        z-index: -1;
        pointer-events: none;
    }

    .dots span {
        position: absolute;
        bottom: -50px;
        left: var(--left);
        width: var(--size);
        height: var(--size);
        background: var(--color, #ffffff);
        border-radius: 50%;
        filter: blur(var(--blur, 0px));
        animation: floatUp linear infinite;
        animation-duration: calc(180s / var(--i));
        animation-delay: var(--delay);
        opacity: var(--opacity, 0.55);
        pointer-events: none;
        box-shadow: 0 0 10px var(--color, rgba(255, 255, 255, 0.8));
        will-change: transform;
    }

    @keyframes floatUp {
        0% {
            transform: translateY(110vh) translateX(0) scale(0.7);
            opacity: 0;
        }
        5% {
            opacity: var(--opacity, 0.55);
        }
        90% {
            opacity: var(--opacity, 0.55);
        }
        100% {
            transform: translateY(-20vh) translateX(20px) scale(1.1);
            opacity: 0;
        }
    }
</style>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
