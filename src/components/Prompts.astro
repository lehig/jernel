---
import "../styles/global.css";
---

<div id="container">

    <div class="wrapper">
        <h1 class="title">Pick a Prompt</h1>

        <div class="cards">
            <a href="/prompt/fiction" class="card">
                <h2>Fiction</h2>
                <p>From fantasy, to sci-fi, to historical fiction, and more.</p>
            </a>
            <a href="/prompt/personal" class="card">
                <h2>Personal</h2>
                <p>From poetry, to journals, to letters, and more.</p>
            </a>
        </div>
    </div>
</div>

<style>
    #container {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
        max-width: 1200px;
        width: 100%;
        padding: 2rem;
    }

    .title {
        font-size: 3.5rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, var(--color-red) 25%, var(--color-blue) 75%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .cards {
        display: flex;
        gap: 2.5rem;
        justify-content: center;
        flex-wrap: wrap;
        width: 100%;
    }

    .card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.03) 0%,
            rgba(255, 255, 255, 0.005) 100%
        );
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 20px;
        padding: 40px 35px;
        width: 320px;
        min-height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow:
            inset 0 1px 1px rgba(255, 255, 255, 0.15),
            0 10px 30px rgba(0, 0, 0, 0.5);
        color: var(--color-red-light);
        text-decoration: none;
    }

    /* Diagonal sheen shine effect on hover */
    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -150%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.15),
            transparent
        );
        transform: skewX(-25deg);
        transition: 0.8s ease;
    }

    .card:hover::before {
        left: 150%;
    }

    /* Fiction Card (Purple Glow) */
    .card:nth-child(1):hover {
        border-color: var(--color-red-light);
        box-shadow:
            inset 0 1px 1px rgba(255, 255, 255, 0.25),
            0 20px 40px var(--color-red-light),
            0 0 30px var(--color-red-light);
        transform: translateY(-8px);
    }

    /* Personal Card (Cyan Glow) */
    .card:nth-child(2):hover {
        border-color: var(--color-blue-light);
        box-shadow:
            inset 0 1px 1px rgba(255, 255, 255, 0.25),
            0 20px 40px var(--color-blue-light),
            0 0 30px var(--color-blue-light);
        transform: translateY(-8px);
    }

    .card h2 {
        font-size: 1.85rem;
        margin: 0 0 1rem 0;
        font-weight: 700;
        letter-spacing: -0.02em;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: all 0.3s ease;
    }

    /* Fiction Card (Red) H2 */
    .card:nth-child(1) h2 {
        background-image: linear-gradient(to right, var(--color-red), var(--color-red-light));
    }

    .card:nth-child(1):hover h2 {
        background-image: linear-gradient(to right, var(--color-red-light), #ffffff);
    }

    /* Personal Card (Blue) H2 */
    .card:nth-child(2) h2 {
        background-image: linear-gradient(to right, var(--color-blue), var(--color-blue-light));
    }

    .card:nth-child(2):hover h2 {
        background-image: linear-gradient(to right, var(--color-blue-light), #ffffff);
    }

    .card p {
        font-size: 1rem;
        margin: 0;
        line-height: 1.5;
        transition: color 0.3s ease;
    }

    /* Fiction Card Paragraph */
    .card:nth-child(1) p {
        color: rgba(255, 255, 255, 0.7);
    }

    .card:nth-child(1):hover p {
        color: var(--color-red-light);
    }

    /* Personal Card Paragraph */
    .card:nth-child(2) p {
        color: rgba(255, 255, 255, 0.7);
    }

    .card:nth-child(2):hover p {
        color: var(--color-blue-light);
    }

    @media (max-width: 640px) {
        #container {
            align-items: flex-start;
            padding-top: 110px;
            padding-bottom: 2rem;
        }
    }
</style>
