---
<footer class="footer">
    <div class="footer-container">
        <p class="footer-copyright">&copy; {new Date().getFullYear()} Jernal. All rights reserved.</p>
        <div class="footer-links">
            <a href="/about" class="footer-link">About</a>
            <a href="/terms" class="footer-link">Terms of Service</a>
            <a href="/privacy" class="footer-link">Privacy Policy</a>
        </div>
    </div>
</footer>

<style>
    .footer {
        width: 100%;
        padding: 2rem 0;
        margin-top: auto;
        background: rgba(10, 10, 10, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        z-index: 10;
        position: relative;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-copyright {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.4);
        margin: 0;
    }

    .footer-links {
        display: flex;
        gap: 1.5rem;
    }

    .footer-link {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .footer-link:hover {
        color: #ffffff;
    }

    @media (max-width: 640px) {
        .footer-container {
            flex-direction: column;
            text-align: center;
            padding: 0 1rem;
            gap: 0.75rem;
        }
        .footer-links {
            justify-content: center;
            width: 100%;
        }
    }
</style>
