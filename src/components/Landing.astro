---
import "../styles/global.css";
---

<div id="container">
    <div class="glass-container">
        <h1 class="jernel">Jernal</h1>

        <h2>We give you the prompt, you generate the story.</h2>
        <p>
            The way this works:

            <ul>
                <li>
                    Each day has two prompts: one fiction and one personal.
                </li>
                <li>
                    You can pick which prompt to respond to (or respond to both,
                    I won't judge)
                </li>
                <li>
                    Once you're done responding, you can copy and paste the response into wherever 
                    you want it stored, or create a profile and save it on here for just 
                    yourself, on the community feed anonymously, or with your username.
                </li>
            </ul>
        </p>
        <hr />
        <div class="cta-section">
            <p>Ready for today's prompt?</p>
            <div class="magnet-wrapper">
                <a href="/prompt" class="btn-cta-landing">Start Writing</a>
            </div>
        </div>
    </div>
</div>

<style is:global>
    .magnet-wrapper {
        display: inline-block;
        padding: 40px;
        position: relative;
    }

    .cta-section {
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .jernel {
        font-size: 4rem;
        font-weight: bold;
        background: linear-gradient(
            135deg,
            var(--color-red) 0%,
            var(--color-red-light) 100%
        );
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-cta-landing {
        display: inline-block;
        padding: 0.5rem 1.2rem;
        border-radius: 20px;
        border: 1px solid var(--color-red-dark);
        background: linear-gradient(
            135deg,
            var(--color-cream-dark) 0%,
            var(--color-cream) 100%
        );
        color: var(--color-red-dark);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        backdrop-filter: blur(8px);
        box-shadow:
            inset 0 1px 1px rgba(255, 255, 255, 0.15),
            0 10px 30px rgba(0, 0, 0, 0.5);
        transform: translate(var(--mx, 0px), var(--my, 0px));
        transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), background 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
        will-change: transform;
    }

    .btn-cta-landing:hover {
        border-color: var(--color-red-light);
        background: linear-gradient(
            135deg,
            var(--color-cream) 0%,
            var(--color-cream-light) 100%
        );
        color: var(--color-red);
        box-shadow:
            0 0 15px rgba(216, 30, 91, 0.3),
            0 4px 15px rgba(0, 0, 0, 0.3);
    }

    ul {
        margin-top: 2rem;
    }

    ul li {
        text-align: left;
        font-weight: bold;
        margin-bottom: 1rem;
    }
</style>

<script>
    const wrappers = document.querySelectorAll('.magnet-wrapper');

    wrappers.forEach((wrapper) => {
        const btn = wrapper.querySelector('.btn-cta-landing') as HTMLElement | null;
        if (!btn) return;

        wrapper.addEventListener('mousemove', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = wrapper.getBoundingClientRect();
            // Calculate mouse coordinates relative to the center of the wrapper
            const x = mouseEvent.clientX - rect.left - rect.width / 2;
            const y = mouseEvent.clientY - rect.top - rect.height / 2;
            
            // Adjust the multiplier (0.35) to increase or decrease the magnetism strength
            btn.style.setProperty('--mx', `${x * 0.35}px`);
            btn.style.setProperty('--my', `${y * 0.35}px`);
        });

        wrapper.addEventListener('mouseleave', () => {
            // Reset position smoothly when mouse leaves the wrapper
            btn.style.setProperty('--mx', '0px');
            btn.style.setProperty('--my', '0px');
        });
    });
</script>
