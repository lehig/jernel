        -webkit-text-fill-color: transparent;
    }

    /* Nav Links Styling */
    .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .nav-link {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        padding: 0.25rem 0;
    }

    .nav-link::after {
        content: '';
