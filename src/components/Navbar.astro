<script>
    let supabaseInstance: any = null;
    async function getSupabase() {
        if (!supabaseInstance) {
            const module = await import('../lib/supabaseClient.js');
            supabaseInstance = module.supabase;
        }
        return supabaseInstance;
    }

    // 1. Auth Toggle UI Elements
    const authOnlyElements = document.querySelectorAll('.auth-only') as NodeListOf<HTMLElement>;
    const guestOnlyElements = document.querySelectorAll('.guest-only') as NodeListOf<HTMLElement>;
    const adminOnlyElements = document.querySelectorAll('.admin-only') as NodeListOf<HTMLElement>;
    const signinBtn = document.getElementById('nav-signin-btn');
    const signoutBtn = document.getElementById('nav-signout-btn');

    async function checkAdmin(session: any) {
        if (!session) {
            adminOnlyElements.forEach(el => el.style.display = 'none');
            return;
        }
        try {
            const sb = await getSupabase();
            const { data, error } = await sb
                .from('admins')
                .select('id')
                .eq('id', session.user.id)
                .maybeSingle();

            if (data) {
                adminOnlyElements.forEach(el => el.style.display = 'inline-block');
            } else {
                adminOnlyElements.forEach(el => el.style.display = 'none');
            }
        } catch (err) {
            console.error('Error checking admin status:', err);
            adminOnlyElements.forEach(el => el.style.display = 'none');
        }
    }

    function updateAuthUI(session: any) {
        if (session) {
            authOnlyElements.forEach(el => el.style.display = 'inline-block');
            guestOnlyElements.forEach(el => el.style.display = 'none');
            checkAdmin(session);
        } else {
            authOnlyElements.forEach(el => el.style.display = 'none');
            guestOnlyElements.forEach(el => el.style.display = 'inline-block');
            adminOnlyElements.forEach(el => el.style.display = 'none');
        }
    }

    async function initAuth() {
        const sb = await getSupabase();
        
        // Initial auth check
        const { data: { session } } = await sb.auth.getSession();
        updateAuthUI(session);

        // Listen to Auth State Changes
        sb.auth.onAuthStateChange((event, session) => {
            updateAuthUI(session);
        });

        // Sign out interaction
        signoutBtn?.addEventListener('click', async () => {
            await sb.auth.signOut();
            window.location.href = '/';
        });
    }

    // Run auth initialization asynchronously
    initAuth();

    // Button interactions
    signinBtn?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-auth-modal'));
    });

    // 2. Magnet Effect
    const wrappers = document.querySelectorAll('.navbar .magnet-wrapper');

    wrappers.forEach((wrapper) => {
        const btn = wrapper.querySelector('.btn-cta') as HTMLElement | null;
        if (!btn) return;

        wrapper.addEventListener('mousemove', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = wrapper.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left - rect.width / 2;
            const y = mouseEvent.clientY - rect.top - rect.height / 2;
            
            btn.style.setProperty('--mx', `${x * 0.35}px`);
            btn.style.setProperty('--my', `${y * 0.35}px`);
        });

        wrapper.addEventListener('mouseleave', () => {
            btn.style.setProperty('--mx', '0px');
            btn.style.setProperty('--my', '0px');
        });
    });
</script>
