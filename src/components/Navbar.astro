        color: #ffffff;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    .magnet-wrapper {
        display: inline-block;
        padding: 10px 15px;
        position: relative;
    }

    .text-signin-wrapper {
        display: flex;
